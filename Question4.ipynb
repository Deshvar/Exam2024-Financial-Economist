import numpy as np
import pandas as pd
import matplotlib.pyplot as plt

# Indlæs initiale værdier og kovariansmatrix
init_values = pd.read_excel("init_values.xlsx", index_col=0)
cov_matrix = pd.read_excel("covariance_matrix.xlsx", index_col=0)

# Parametre
time_steps = 52  # Ugevis simulering
dt = 1 / time_steps
mu = np.zeros(cov_matrix.shape[0])
mu[1:3] = [0.07 * dt, 0.06 * dt]  # Angivet i opgaven

# Simulér markedsinvarianter
np.random.seed(42)
num_simulations = 10000
delta_X = np.random.multivariate_normal(mu, cov_matrix.values * dt, size=(num_simulations, time_steps))
X_t = np.cumsum(delta_X, axis=1)  # Kumulativ sum

# Udregning af slutværdier
FX_0 = init_values.loc['FX', 'Value']
V_US_0 = init_values.loc['V_US,local', 'Value']
V_EUR_0 = init_values.loc['V_EUR', 'Value']

FX_t = FX_0 * np.exp(X_t[:, :, 0])  # FX rate
V_US_t = V_US_0 * np.exp(X_t[:, :, 1])  # US aktier
V_EUR_t = V_EUR_0 * np.exp(X_t[:, :, 2])  # EUR aktier

# Beregn obligationspriser (eksempel for 4-årige obligationer)
def bond_price(yield_curve, time_to_maturity):
    """Beregn prisen på en nulpunktsobligation."""
    return np.exp(-yield_curve * time_to_maturity)

# Simulerede obligationspriser
Z_US_4Y = bond_price(X_t[:, :, 9], 4)  # USD 4-årig obligation
Z_EUR_4Y = bond_price(X_t[:, :, 4], 4)  # EUR 4-årig obligation

# Saml vektoren P1
P1 = np.column_stack([FX_t[:, -1], V_US_t[:, -1], V_EUR_t[:, -1], Z_US_4Y[:, -1], Z_EUR_4Y[:, -1]])

# Beregn statistikker
P1_mean = np.mean(P1, axis=0)
P1_cov = np.cov(P1.T)

# Visualisering
plt.figure(figsize=(10, 6))
plt.hist(P1[:, 0], bins=50, alpha=0.7, label="Simulated FX")
plt.title("Distribution of FX_1")
plt.xlabel("FX Rate")
plt.ylabel("Frequency")
plt.legend()
plt.show()

print("Mean of P1:", P1_mean)
print("Covariance matrix of P1:\n", P1_cov)

